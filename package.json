{
  "name": "capsium-viewer-webextension",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Browser extension (MV3) that loads and renders Capsium .cap packages in the browser",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "wxt prepare",
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "harness:build": "esbuild harness/serve.ts --bundle --platform=node --target=node24 --format=esm --outfile=harness/serve.mjs --banner:js=\"import { createRequire as __harnessCreateRequire } from 'node:module'; const require = __harnessCreateRequire(import.meta.url);\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "fflate": "^0.8.3",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.27.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.11.0",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27",
    "yaml": "^2.9.0"
  }
}
